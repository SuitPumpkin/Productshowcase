		SubstrateRequestSharedLocalBasisTangent(SharedLocalBasisTypes, SharedLocalBasisIndex);
	}
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 3 ))-1)<<( (((((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1)			+ 1)				+ 1) )))) | ((( 0 ) &  ((1u<<( 3 ))-1)) << ( (((((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1)			+ 1)				+ 1) ));
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 2 ))-1)<<( ((((((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1)			+ 1)				+ 1)			+ 3) )))) | ((( SharedLocalBasisIndex ) &  ((1u<<( 2 ))-1)) << ( ((((((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1)			+ 1)				+ 1)			+ 3) ));
	  SubstrateData.InlinedBSDF .Emissive = Emissive ;
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 3 ))-1)<<( ((0			+ 1)			+ 1) )))) | ((( SSSType ) &  ((1u<<( 3 ))-1)) << ( ((0			+ 1)			+ 1) ));
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 1 ))-1)<<( 0 )))) | ((( bHasAnisotropy ) &  ((1u<<( 1 ))-1)) << ( 0 ));
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 1 ))-1)<<( (0			+ 1) )))) | ((( 0 ) &  ((1u<<( 1 ))-1)) << ( (0			+ 1) ));
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 1 ))-1)<<( ((((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1)			+ 1) )))) | ((( bIsThin ? 1 : 0 ) &  ((1u<<( 1 ))-1)) << ( ((((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1)			+ 1) ));
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 1 ))-1)<<( ((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1) )))) | ((( bMFPPlugged ? 1 : 0 ) &  ((1u<<( 1 ))-1)) << ( ((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1) ));
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 1 ))-1)<<( ((((0			+ 1)			+ 1)			+ 3)		+ 1) )))) | ((( bHasHaziness ) &  ((1u<<( 1 ))-1)) << ( ((((0			+ 1)			+ 1)			+ 3)		+ 1) ));
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 1 ))-1)<<( (((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1) )))) | ((( bHasFuzz ) &  ((1u<<( 1 ))-1)) << ( (((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1) ));
	  SubstrateData.InlinedBSDF .ThicknessCm = ThicknessCm ;
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 1 ))-1)<<( (((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1) )))) | ((( any(F90 < 1.0f) ) &  ((1u<<( 1 ))-1)) << ( (((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1) ));
	  SubstrateData.InlinedBSDF .VGPRs[0].xyz			= DiffuseAlbedo;
	  SubstrateData.InlinedBSDF .VGPRs[1].xyz						= F0;
	  SubstrateData.InlinedBSDF .VGPRs[2].xyz						= F90;
	  SubstrateData.InlinedBSDF .VGPRs[0].w		= Roughness;
	  SubstrateData.InlinedBSDF .VGPRs[1].w		= Anisotropy;
	  SubstrateData.InlinedBSDF .Haziness					= PackHaziness(Haziness);
	if (SSSType == (4u))
	{
		  SubstrateData.InlinedBSDF .VGPRs[3].x			= float(SSSProfileID);
		  SubstrateData.InlinedBSDF .VGPRs[3].y	= SSSMFPScale;
		  SubstrateData.InlinedBSDF .VGPRs[3].z	= ThicknessCm;
	}
	else
	{
		  SubstrateData.InlinedBSDF .VGPRs[3].xyz				= SSSMFP * SSSMFPScale;
	}
	  SubstrateData.InlinedBSDF .VGPRs[3].w			= SSSPhaseAnisotropy;
	  SubstrateData.InlinedBSDF .VGPRs[4].w		= FuzzAmount;
	  SubstrateData.InlinedBSDF .VGPRs[4].xyz		= FuzzColor;
	  SubstrateData.InlinedBSDF .VGPRs[2].w		= FuzzRoughness;
	SubstrateData.InlinedBSDF.TmpMFP = SSSMFP * SSSMFPScale;
	SubstrateData.InlinedBSDF.Coverage = 1.0f;
	SubstrateData.PreviewColor = lerp(DiffuseAlbedo, F0, F0RGBToMetallic(F0));
	return SubstrateData;
}
