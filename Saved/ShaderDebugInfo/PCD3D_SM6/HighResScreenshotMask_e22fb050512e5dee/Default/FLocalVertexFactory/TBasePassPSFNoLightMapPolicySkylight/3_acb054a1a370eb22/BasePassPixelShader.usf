{
	FSubstrateData SubstrateData = GetInitialisedSubstrateData();
	   SubstrateData.InlinedBSDF .State = ( SubstrateData.InlinedBSDF .State & (~ ( ((1u<<( 3 ))-1)<<( (((((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1)			+ 1)				+ 1) )))) | ((( 2 ) &  ((1u<<( 3 ))-1)) << ( (((((((((0			+ 1)			+ 1)			+ 3)		+ 1)			+ 1)				+ 1)			+ 1)			+ 1)				+ 1) ));
